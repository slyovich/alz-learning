# Entra ID (Azure AD) Configuration — Client Application
# -------------------------------------------------------

# The Tenant ID of your Entra ID directory
AZURE_TENANT_ID=your-tenant-id

# The Application (client) ID of the CLIENT App Registration
AZURE_CLIENT_ID=your-client-app-client-id

# The Client Secret of the CLIENT App Registration
AZURE_CLIENT_SECRET=your-client-secret

# The Application (client) ID of the API App Registration (audience)
API_CLIENT_ID=your-api-client-id

# The base URL of the Hello World API
API_BASE_URL=http://127.0.0.1:8000
